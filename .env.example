# ty_research_monitor.js (TY_Research 颱風監控 Routine) 所需環境變數

# CWA_API_KEY: 中央氣象署開放資料平台授權碼
CWA_API_KEY="MY_CWA_API_KEY"

# NOTION_TOKEN: Notion Integration Token,用於讀寫執行進度
NOTION_TOKEN="MY_NOTION_TOKEN"

# NOTION_STATE_PAGE_ID: 用來存放「上次處理到的時間戳記」的 Notion 頁面 ID
NOTION_STATE_PAGE_ID="MY_NOTION_STATE_PAGE_ID"

# GMAIL_USER: 寄件 Gmail 帳號
GMAIL_USER="MY_GMAIL_ADDRESS"

# GMAIL_APP_PASSWORD: Gmail 應用程式密碼(非登入密碼,於 Google 帳號安全性設定中另外產生)
GMAIL_APP_PASSWORD="MY_GMAIL_APP_PASSWORD"
